{
  "$schema": "https://json-schema.org/draft-07/schema#",
  "title": "VTOM Helm Chart Values",
  "type": "object",
  "properties": {
    "namespace": { "type": "string" },
    "global": {
      "type": "object",
      "properties": {
        "imageRegistry": { "type": "string" },
        "imagePullSecrets": { "type": "array" }
      }
    },
    "vtom": {
      "type": "object",
      "properties": {
        "enabled": { "type": "boolean" },
        "image": {
          "type": "object",
          "properties": {
            "repository": { "type": "string" },
            "tag": { "type": "string" },
            "pullPolicy": { "type": "string", "enum": ["Always", "IfNotPresent", "Never"] }
          }
        },
        "serverName": { "type": "string" },
        "timezone": { "type": "string" },
        "ingress": {
          "type": "object",
          "properties": {
            "host": { "type": "string" },
            "annotations": { "type": "object" }
          }
        },
        "podAnnotations": { "type": "object" },
        "podLabels": { "type": "object" }
      }
    },
    "itc": {
      "type": "object",
      "properties": {
        "enabled": { "type": "boolean" },
        "image": {
          "type": "object",
          "properties": {
            "repository": { "type": "string" },
            "tag": { "type": "string" },
            "pullPolicy": { "type": "string", "enum": ["Always", "IfNotPresent", "Never"] }
          }
        },
        "ingress": {
          "type": "object",
          "properties": {
            "host": { "type": "string" },
            "annotations": { "type": "object" }
          }
        },
        "podAnnotations": { "type": "object" },
        "podLabels": { "type": "object" }
      }
    },
    "itm": {
      "type": "object",
      "properties": {
        "enabled": { "type": "boolean" },
        "image": {
          "type": "object",
          "properties": {
            "repository": { "type": "string" },
            "tag": { "type": "string" },
            "pullPolicy": { "type": "string", "enum": ["Always", "IfNotPresent", "Never"] }
          }
        },
        "ingress": {
          "type": "object",
          "properties": {
            "host": { "type": "string" },
            "annotations": { "type": "object" }
          }
        },
        "podAnnotations": { "type": "object" },
        "podLabels": { "type": "object" }
      }
    },
    "mft": {
      "type": "object",
      "properties": {
        "enabled": { "type": "boolean" },
        "image": {
          "type": "object",
          "properties": {
            "repository": { "type": "string" },
            "tag": { "type": "string" },
            "pullPolicy": { "type": "string", "enum": ["Always", "IfNotPresent", "Never"] }
          }
        },
        "ports": {
          "type": "object",
          "properties": {
            "https": { "type": "integer" },
            "sftp": { "type": "integer" }
          }
        },
        "sftpService": {
          "type": "object",
          "properties": {
            "enabled": { "type": "boolean" },
            "loadBalancerIP": { "type": "string" },
            "hostname": { "type": "string" },
            "loadBalancerSourceRanges": { "type": "array" },
            "annotations": { "type": "object" }
          }
        },
        "ingress": {
          "type": "object",
          "properties": {
            "host": { "type": "string" },
            "annotations": { "type": "object" }
          }
        },
        "externalEgress": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "port": { "type": "integer" },
              "protocol": { "type": "string", "enum": ["TCP", "UDP"] },
              "cidr": { "type": "string" }
            }
          }
        },
        "podAnnotations": { "type": "object" },
        "podLabels": { "type": "object" }
      }
    },
    "database": {
      "type": "object",
      "required": ["host"],
      "properties": {
        "host": {
          "type": "string",
          "description": "FQDN ou IP du serveur PostgreSQL. Obligatoire (sauf GCP avec Cloud SQL Proxy qui utilise 127.0.0.1)."
        },
        "port": { "type": "string" }
      }
    },
    "dbProxy": {
      "type": "object",
      "properties": {
        "enabled": { "type": "boolean" },
        "type": { "type": "string", "enum": ["socat", "cloudsql-proxy"] }
      }
    },
    "secrets": {
      "type": "object",
      "properties": {
        "provider": {
          "type": "string",
          "enum": ["kubernetes", "external-secrets"]
        },
        "refreshInterval": { "type": "string" }
      }
    },
    "serviceAccount": {
      "type": "object",
      "properties": {
        "workloadIdentity": {
          "type": "object",
          "properties": {
            "enabled": { "type": "boolean" }
          }
        }
      }
    },
    "ingress": {
      "type": "object",
      "properties": {
        "enabled": { "type": "boolean" },
        "className": { "type": "string" }
      }
    },
    "tls": {
      "type": "object",
      "properties": {
        "enabled": { "type": "boolean" },
        "provider": {
          "type": "string",
          "enum": ["cert-manager", "secret", "none"]
        }
      }
    },
    "networkPolicy": {
      "type": "object",
      "properties": {
        "enabled": { "type": "boolean" },
        "lbHealthCheckCidrs": { "type": "array", "items": { "type": "string" } },
        "internalCidr": { "type": "string" }
      }
    },
    "podDisruptionBudget": {
      "type": "object",
      "properties": {
        "enabled": { "type": "boolean" }
      }
    },
    "openshift": {
      "type": "object",
      "properties": {
        "enabled": { "type": "boolean" }
      }
    }
  }
}
